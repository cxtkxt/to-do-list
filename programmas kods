    task = task_entry.get().strip()
    category = category_entry.get().strip()
    date = date_entry.get().strip()
    if task == "Uzdevums":
        task = ""
    if category == "Kategorija, piem. skola":
        category = ""
    if date == "Termiņš, piem. 15.05":
        date = ""
    if task == "":
        messagebox.showwarning("Kļūda", "Lūdzu ievadi uzdevumu!")

    else:
        if category == "":
            category = "Bez kategorijas"
        if date == "":
            date = "nav termiņa"
        full_task = f"[{category}] {task} | līdz: {date}"
        task_list.insert(tk.END, full_task)
        add_placeholder(task_entry, "Uzdevums")
        add_placeholder(category_entry, "Kategorija, piem. skola")
        add_placeholder(date_entry, "Termiņš, piem. 15.05")

        save_tasks()

def delete_task():
    try:
        selected_task = task_list.curselection()[0]
        task_list.delete(selected_task)
        save_tasks()

    except IndexError:
        messagebox.showwarning("Kļūda", "Vispirms izvēlies uzdevumu!")

def mark_done():
    try:
        selected_task = task_list.curselection()[0]
        text = task_list.get(selected_task)
        if not text.startswith("✓ "):
            task_list.delete(selected_task)
            task_list.insert(selected_task, "✓ " + text.upper())
            task_list.selection_clear(0, tk.END)
            save_tasks()

    except IndexError:
        messagebox.showwarning("Kļūda", "Vispirms izvēlies uzdevumu!")

